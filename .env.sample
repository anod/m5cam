# WiFi credentials
WIFI_SSID=YOUR_WIFI_SSID
WIFI_PASSWORD=YOUR_WIFI_PASSWORD

# mDNS hostname — device will be reachable at http://<name>.local
MDNS_HOSTNAME=m5cam

# OTA updates (available after one USB flash with OTA firmware)
# OTA_PORT=3232
# OTA_PASSWORD=change-me

# Optional PY260 night tuning
# PY260_WB_MODE_SETTING=4   # 0=auto, 1=sunny, 2=cloudy, 3=office, 4=home
